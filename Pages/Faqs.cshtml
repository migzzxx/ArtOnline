@page
@model ArtOnline.Pages.FaqsModel

<!DOCTYPE html>
<html lang="en">

<head>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings:FAQs</title>
    <link rel="stylesheet" href="~/css/setacc.css">
    <style>
        .set1 { color: inherit !important; border-color: #000000 !important; }
        .set2 { color: #3e4a8e !important; border-color: #3e4a8e !important; }
        .faq-content {
            display: flex;
            flex-direction: column;
            padding: 5px 60px 40px 60px;
            gap: 10px;
            overflow-y: auto;
            height: 100%;
        }
        .faq-content h3 {
            font-family: 'Geom', sans-serif;
            font-size: 1.35rem;
            font-weight: 600;
            color: black;
            margin-top: 24px;
        }
        .faq-content p {
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            font-weight: 400;
            color: #2b2b2b;
            line-height: 1.6;
            margin-bottom: 5px;
        }
    </style>
</head>

<body>
    <img src="~/assets/LOGO 2 ALT.png" class="bgpic">

    <div class="header">
        <div class="left">
            <img src="~/assets/LOGO 2.png" alt="LOGO-2" border="0">
            <h1>ArtOnline</h1>
        </div>
        <div class="right">
            <a class="home" href="/Home">Home</a>
            <a class="gallery" href="/Gallery">Gallery</a>
            <a class="comm" href="/Commission">Commission</a>
            <a class="artist" href="/Artist">Artist</a>
            <a class="set" href="/Settings">Settings</a>
        </div>
    </div>

    <div class="mid">
        <div class="ml">
            <div class="tabui">
                <div class="tabid">
                    <h1>FAQs</h1>
                </div>

                <div class="faq-content">
                    
                    <h3>How do I submit a commission request?</h3>
                    <p>
                        You can submit a commission by tapping the "+" button in the Fill Out Form, then fill out the commission form and provide the necessary details and references before tapping the submit button.
                    </p>

                    <h3>How will I know if my commission is accepted?</h3>
                    <p>
                        You can check the Commission tab from time to time to see whether the artist has reviewed or followed up on your request.
                    </p>

                    <h3>Can I edit my commission request after submission?</h3>
                    <p>
                        Yes, pending requests may still be edited before they are accepted by the artist.
                    </p>

                    <h3>How long does it take to complete a commission?</h3>
                    <p>
                        Completion time depends on the complexity of the artwork and the current commission queue.
                    </p>

                    <h3>Can I cancel my commission request?</h3>
                    <p>
                        The artist reserves the right to accept or decline any request. Clients may cancel pending requests before acceptance through communications. Accepted commissions may only be canceled under agreed conditions.
                    </p>

                </div>
            </div>
        </div>
        <div class="mr">
            <div class="setui">
                <div class="iconwrap">
                    <span class="material-symbols-rounded">settings</span>
                </div>
                <div class="divwrap">
                    <a href="/Settings"><div class="set1">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Account</p>
                    </div></a>
                    <a href="/Faqs"><div class="set2">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>FAQs</p>
                    </div></a>
                    <a href="/Reviews"><div class="set3">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Reviews</p>
                    </div></a>
                    <a href="/Terms"><div class="set4">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Terms</p>
                    </div></a>
                    <a href="/Privacy"><div class="set5">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Privacy Policy</p>
                    </div></a>
                </div>
                <img src="~/assets/MAIN LOGO.png" alt="MAIN-LOGO" border="0">
                <div class="iconwrap">
                    <a href="/Logout"><span class="exit material-symbols-rounded">exit_to_app</span></a>
                </div>
            </div>
        </div>
