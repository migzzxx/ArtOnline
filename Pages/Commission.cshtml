@page
@model ArtOnline.Pages.CommissionModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Commissions</title>
    <link rel="stylesheet" href="~/css/comm.css">
</head>

<body>
    <div class="header">
        <div class="left">
            <img src="~/assets/LOGO 2.png" alt="LOGO-2" border="0">
            <h1>ArtOnline</h1>
        </div>
        <div class="right">
            <a class="home" href="/Home">Home</a>
            <a class="gallery">Gallery</a>
            <a class="comm" href="/Commission">Commission</a>
            <a class="artist" href="/Artist">Artist</a>
            <a class="set" href="/Settings">Settings</a>
        </div>
    </div>

    <div class="mid">
        <div class="midl">
            <div class="top">
                <div class="divh">
                    <h1>Commissions</h1>
                    <div class="wrap">
                        <span class="material-symbols-rounded" style="font-weight: lighter;">donut_large</span>
                        <span class="material-symbols-rounded" style="font-weight: bold;">check</span>
                    </div>
                </div>
                @foreach (var c in Model.Commissions)
                {
                    <div class="queue">
                        <div class="pleft" style="background-color: @(c.Status == "Pending" ? "#ec7c7c" : c.Status == "Working" ? "#ecb07c" : "#7cec7c")"></div>
                        <div class="pending">
                            <div class="pmid">
                                <p class="stat" style="color: @(c.Status == "Pending" ? "#9e3e3e" : c.Status == "Working" ? "#9e7a3e" : "#3e9e3e")">[<span>@c.Status</span>]</p>
                                <div class="date">
                                    <p>@c.DateSubmitted.ToString("d MMM")</p>
                                    <p class="dot">●</p>
                                    <p>@c.TimeSubmitted</p>
                                </div>
                            </div>
                            <div class="pright">
                                <p class="name">@c.Subject</p>
                                <div class="attr">
                                    @if (c.RushCommission)
                                    {
                                        <p class="a1" style="font-weight: bold;">Rush</p>
                                        <p class="dot">●</p>
                                    }
                                    <p class="a2">@c.CommissionType1</p>
                                    <p class="dot">●</p>
                                    <p class="a3">@c.CommissionType2</p>
                                    <p class="dot">●</p>
                                    <p class="a4">@c.CommissionType3</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="bot">
                <div class="divh">
                    <h1>Chats</h1>
                </div>
            </div>
        </div>
        <div class="midr">
            <div class="divh">
                <h1>Fill Out Form</h1>
                <p>(Commission Status: OPEN)</p>
                <button type="button" id="toggleFormBtn">
                    <span class="material-symbols-rounded">add_2</span>
                </button>
            </div>
            <div class="wrap">
                @if (Model.ShowSuccess)
                {
                    <div class="form" style="padding: 25px;">
                        <div class="fhead">
                            <h1>Form Submitted</h1>
                            <p>Thank you for choosing our service!</p>
                            <p>You will be notified once the artist has reviewed and made a decision. Please wait for updates.</p>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="form" id="commissionForm">
                        <div class="fhead">
                            <h1 style="color: #9e3e3e;">@Model.ErrorMessage</h1>
                        </div>
                    </div>
                }

                <form method="post" enctype="multipart/form-data" id="formContent" style="display: none;">
                    <div class="form">
                        <div class="fhead">
                            <h1>Commission Request</h1>
                            <p>Fill out the form below to submit your commission request. All required fields must be completed.</p>
                        </div>
                        <div class="cont">
                            <h1>Contact Information</h1>
                            <div class="inputs">
                                <div class="input">
                                    <p>Email Address <span style="color:red;">*</span></p>
                                    <input type="text" class="box" name="Email" value="@Model.Email" required>
                                </div>
                                <div class="input">
                                    <p>Contact Number <span style="color:red;">*</span></p>
                                    <input type="tel" class="box" name="ContactNumber" id="contactNumber" value="@Model.ContactNumber" pattern="[0-9]*" required>
                                </div>
                                <div class="input">
                                    <p>Social Account Link <span style="color:red;">*</span></p>
                                    <input type="text" class="box" name="SocialAccountLink" value="@Model.SocialAccountLink" required>
                                </div>
                            </div>
                        </div>
                        <div class="det">
                            <h1>Art Details</h1>
                            <div class="inputs">
                                <div class="input">
                                    <p>Rush Commission? <span style="color:red;">*</span></p>
                                    <select name="RushCommission" required>
                                        <option value="">-- Select --</option>
                                        <option value="Yes">Yes</option>
                                        <option value="No">No</option>
                                    </select>
                                </div>
                                <div class="input">
                                    <p>Subject <span style="color:red;">*</span></p>
                                    <input type="text" placeholder="Provide brief summary of your art request" class="box" name="Subject" value="@Model.Subject" required>
                                </div>
                                <div class="input">
                                    <p>Character Sheet (PNG/JPG)</p>
                                    <label class="text">
                                        <span class="placeholder">Upload a clear and detailed image of your OC/s (JPEG/PNG)</span>
                                        <span class="material-symbols-rounded">upload</span>
                                    </label>
                                    <input type="file" accept="image/jpeg, image/png" class="file" name="CharacterSheet">
                                </div>
                                <div class="input">
                                    <p>Character Reference</p>
                                    <input type="text" placeholder="Name and describe the existing character/s for this artwork" class="box" name="CharacterReference">
                                </div>
                                <p>Commission Type <span style="color:red;">*</span></p>
                                <div class="comwrap">
                                    <div class="input">
                                        <select name="CommissionType1" required>
                                            <option value="">-- Body Type --</option>
                                            <option value="Icon">Icon</option>
                                            <option value="Bust-Up">Bust-Up</option>
                                            <option value="Half Body">Half Body</option>
                                            <option value="Whole Body">Whole Body</option>
                                        </select>
                                    </div>
                                    <div class="input">
                                        <select name="CommissionType2" required>
                                            <option value="">-- Persons --</option>
                                            <option value="One Person">One Person</option>
                                            <option value="Two">Two</option>
                                            <option value="Three">Three</option>
                                            <option value="More">More</option>
                                        </select>
                                    </div>
                                    <div class="input">
                                        <select name="CommissionType3" required>
                                            <option value="">-- Style --</option>
                                            <option value="Sketch">Sketch</option>
                                            <option value="Fully Rendered">Fully Rendered</option>
                                            <option value="Chibi">Chibi</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="input">
                                    <p>Reference Pose <span style="color:red;">*</span></p>
                                    <label class="text">
                                        <span class="placeholder">Upload reference pose image (JPEG/PNG)</span>
                                        <span class="material-symbols-rounded">upload</span>
                                    </label>
                                    <input type="file" accept="image/jpeg, image/png" class="file" name="ReferencePose" required>
                                </div>
                                <div class="input">
                                    <p>Reference Background (Optional)</p>
                                    <label class="text">
                                        <span class="placeholder">Upload reference background image (JPEG/PNG)</span>
                                        <span class="material-symbols-rounded">upload</span>
                                    </label>
                                    <input type="file" accept="image/jpeg, image/png" class="file" name="ReferenceBackground">
                                </div>
                                <div class="input">
                                    <p>Canvas Size <span style="color:red;">*</span></p>
                                    <select name="CanvasSize" id="canvasSizeSelect" required>
                                        <option value="">-- Select Size --</option>
                                        <option value="1080x1080">1080 x 1080</option>
                                        <option value="1920x1080">1920 x 1080</option>
                                        <option value="2480x3508">2480 x 3508 (A4)</option>
                                        <option value="3508x2480">3508 x 2480 (A4 Landscape)</option>
                                        <option value="4000x4000">4000 x 4000</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="input" id="customCanvasInput" style="display: none;">
                                    <p>Custom Canvas Size</p>
                                    <input type="text" placeholder="Enter your preferred size (e.g. 3000x2000)" class="box" name="CustomCanvasSize">
                                </div>
                                <div class="input">
                                    <p>Other Notes</p>
                                    <textarea class="box" name="OtherNotes" placeholder="Provide any additional information you want the artist to be aware of" rows="4" style="resize: vertical; min-height: 80px;">@Model.OtherNotes</textarea>
                                </div>
                            </div>
                        </div>
                        <div class="mop">
                            <h1>Mode of Payment</h1>
                            <div class="inputs">
                                <div class="input">
                                    <p>Payment Method <span style="color:red;">*</span></p>
                                    <select name="ModeOfPayment" required>
                                        <option value="">-- Select --</option>
                                        <option value="GCash">GCash</option>
                                        <option value="PayMaya">PayMaya</option>
                                        <option value="Game Credits">Game Credits</option>
                                    </select>
                                </div>
                                <div class="input">
                                    <p>Estimated Budget <span style="color:red;">*</span></p>
                                    <input type="text" placeholder="Enter your estimated budget" class="box" name="EstimatedBudget" required>
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="submit">Submit Commission</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="footer">
        <p>&copy; Art Online, 2026. All rights reserved.</p>
        <div class="cont">
            <p>Connect w/ Developers:</p>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
            </svg>
            <a href="">developers@@gmail.com</a>
        </div>
    </div>

<script>
    // Toggle form visibility
    document.getElementById('toggleFormBtn').addEventListener('click', () => {
        const form = document.getElementById('formContent');
        form.style.display = form.style.display === 'none' ? 'block' : 'none';
    });

    // Contact number: only accept numeric input
    document.getElementById('contactNumber').addEventListener('input', function(e) {
        this.value = this.value.replace(/[^0-9]/g, '');
    });

    // Canvas size: show custom input when "Other" is selected
    document.getElementById('canvasSizeSelect').addEventListener('change', function() {
        const customInput = document.getElementById('customCanvasInput');
        customInput.style.display = this.value === 'Other' ? 'flex' : 'none';
    });

    // File input: show filename in label when file is selected
    document.querySelectorAll('.file').forEach(input => {
        input.addEventListener('change', function() {
            const label = this.previousElementSibling;
            const placeholder = label.querySelector('.placeholder');
            if (this.files.length > 0) {
                placeholder.textContent = this.files[0].name;
                // Show remove button
                let removeBtn = this.parentElement.querySelector('.remove-file');
                if (!removeBtn) {
                    removeBtn = document.createElement('button');
                    removeBtn.type = 'button';
                    removeBtn.className = 'remove-file';
                    removeBtn.textContent = '✕';
                    removeBtn.style.cssText = 'position:absolute; top:8px; right:10px; background:none; border:none; color:#9e3e3e; font-weight:700; font-size:1.2rem; cursor:pointer; z-index:5;';
                    label.style.position = 'relative';
                    label.appendChild(removeBtn);
                    removeBtn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        input.value = '';
                        placeholder.textContent = label.dataset.original || 'Upload a file';
                        removeBtn.remove();
                    });
                }
            }
        });
    });

    // Make labels clickable to trigger file inputs
    document.querySelectorAll('label.text').forEach(label => {
        // Store original placeholder text
        const placeholder = label.querySelector('.placeholder');
        if (placeholder) label.dataset.original = placeholder.textContent;
        label.style.cursor = 'pointer';
        label.addEventListener('click', () => {
            const fileInput = label.nextElementSibling;
            if (fileInput && fileInput.type === 'file') {
                fileInput.click();
            }
        });
    });
</script>

</body>
</html>
