@page
@model ArtOnline.Pages.CommissionModel
@removeTagHelper "Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers"
@using System.IO

<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Commissions</title>
    <link rel="stylesheet" href="~/css/comm.css">
</head>

<body>
    <div class="header">
        <div class="left">
            <img src="~/assets/LOGO 2.png" alt="LOGO-2" border="0">
            <h1>ArtOnline</h1>
        </div>
        <div class="right">
            <a class="home" href="/Home">Home</a>
            <a class="gallery" href="/Gallery">Gallery</a>
            <a class="comm" href="/Commission">Commission</a>
            <a class="artist" href="/Artist">Artist</a>
            <a class="set" href="/Settings">Settings</a>
        </div>
    </div>

    <div class="mid">
        <div class="midl">
            <div class="top">
                <div class="divh">
                    <h1>Commissions</h1>
                    <div class="wrap">
                        <span class="material-symbols-rounded" id="filterProgress" style="font-weight: lighter; cursor:pointer;">donut_large</span>
                        <span class="material-symbols-rounded" id="filterCheck" style="font-weight: bold; cursor:pointer;">check</span>
                    </div>
                </div>
                <div style="overflow-y:auto; flex:1; min-height:0;">
                @foreach (var c in Model.Commissions)
                {
                    <div class="queue" data-status="@c.Status" style="cursor: pointer;" onclick="saveFilterState(); window.location.href='/Commission?commissionId=@c.Id'">
                        <div class="pleft" style="background-color: @(c.Status == "Pending" ? "#ec7c7c" : c.Status == "Working" ? "#ecb07c" : "#7cec7c")"></div>
                        <div class="pending">
                            <div class="pmid">
                                <p class="stat" style="color: @(c.Status == "Pending" ? "#9e3e3e" : c.Status == "Working" ? "#9e7a3e" : "#3e9e3e")">[<span>@c.Status</span>]</p>
                                <div class="date">
                                    <p>@c.DateSubmitted.ToString("d MMM")</p>
                                    <p class="dot">●</p>
                                    <p>@c.TimeSubmitted</p>
                                </div>
                            </div>
                            <div class="pright">
                                <p class="name">@c.Subject</p>
                                <div class="attr">
                                    @if (c.RushCommission)
                                    {
                                        <p class="a1" style="font-weight: bold;">Rush</p>
                                        <p class="dot">●</p>
                                    }
                                    <p class="a2">@c.CommissionType1</p>
                                    <p class="dot">●</p>
                                    <p class="a3">@c.CommissionType2</p>
                                    <p class="dot">●</p>
                                    <p class="a4">@c.CommissionType3</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                </div>
            </div>
            <div class="bot">
                <div class="divh">
                    <h1>Chats</h1>
                </div>
                <div class="chat-area" id="chatArea">
                    <div style="flex:1;"></div>
                    @foreach (var msg in Model.ChatMessages)
                    {
                        var timeDiff = TimeHelper.Now - msg.SentAt;
                        var timeDisplay = timeDiff.TotalHours < 24 ? msg.SentAt.ToString("h:mm tt") : msg.SentAt.ToString("dd/MM/yyyy");
                        var displayName = msg.IsArtist ? "Amoreivc" : "You";
                        <div class="chat-msg" data-msg-id="@msg.Id">
                            <span class="sender">@displayName</span>
                            @if (!string.IsNullOrEmpty(msg.ImagePath))
                            {
                                <div class="bubble @(msg.IsArtist ? "artist-msg" : "user-msg")" style="cursor:pointer;" onclick="showImagePreviewUrl('@msg.ImagePath')">📷 @msg.Message</div>
                            }
                            else
                            {
                                <div class="bubble @(msg.IsArtist ? "artist-msg" : "user-msg")">@msg.Message</div>
                            }
                            <span class="time">@timeDisplay</span>
                        </div>
                    }
                </div>
                @if (Model.SelectedCommissionId > 0)
                {
                    <form method="post" asp-page-handler="SendMessage" class="chat-input-area">
                        <input type="hidden" name="SelectedCommissionId" value="@Model.SelectedCommissionId" />
                        <input type="text" name="ChatMessageText" placeholder="Type a message..." required />
                        <button type="button" onclick="document.getElementById('chatImageInput').click()" style="background:none; border:none; cursor:pointer; display:flex; align-items:center; padding:0 5px;"><span class="material-symbols-rounded" style="font-size:1.4rem; color:#888;">image</span></button>
                        <button type="submit"><span class="material-symbols-rounded">send</span></button>
                    </form>
                    <input type="file" id="chatImageInput" accept="image/jpeg,image/png" style="display:none;" onchange="showChatImageConfirm(this)" />
                }
            </div>
        </div>
        <div class="midr">
            <div class="divh">
                <h1>Fill Out Form</h1>
                @if (Model.IsCommissionOpen)
                {
                    <p>(Commission Status: <span style="color:green;">OPEN</span>)</p>
                }
                else
                {
                    <p>(Commission Status: <span style="color:#9e3e3e;">CLOSED</span>)</p>
                }
                <div style="display:flex; align-items:center; position:absolute; right:15px; gap:15px;">
                    @if (Model.ViewingCommission != null && Model.ViewingCommission.Status == "Pending")
                    {
                        @if (Model.IsEditing)
                        {
                            <a href="#" id="discardEditBtn" onclick="handleDiscardEdit(event)" style="background:none; border:none; cursor:pointer; display:flex; align-items:center; text-decoration:none; margin-right:10px;">
                                <span class="material-symbols-rounded" style="font-size:1.8rem; color:#9e3e3e;">close</span>
                            </a>
                        }
                        else
                        {
                            <a href="/Commission?commissionId=@Model.SelectedCommissionId&edit=true" style="background:none; border:none; cursor:pointer; display:flex; align-items:center; text-decoration:none; margin-right:10px;">
                                <span class="material-symbols-rounded" style="font-size:1.8rem; color:#1b1b1b;">edit</span>
                            </a>
                        }
                    }
                    <button type="button" id="toggleFormBtn" style="background:none; border:none; cursor:pointer; display:flex; align-items:center; position:static; @(Model.IsCommissionOpen ? "" : "display:none;") @(Model.IsEditing ? "opacity:0.35; pointer-events:none;" : "")">
                        <span class="material-symbols-rounded">add_2</span>
                    </button>
                </div>
            </div>
            <div class="wrap">
                @if (Model.ShowSuccess)
                {
                    <div class="form" style="padding: 25px;">
                        <div class="fhead">
                            <h1>Form Submitted</h1>
                            <p>Thank you for choosing our service!</p>
                            <p>You will be notified once the artist has reviewed and made a decision. Please wait for updates.</p>
                        </div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="form" id="commissionForm">
                        <div class="fhead">
                            <h1 style="color: #9e3e3e;">@Model.ErrorMessage</h1>
                        </div>
                    </div>
                }
                else if (Model.ViewingCommission != null)
                {
                    @* === VIEW/EDIT EXISTING COMMISSION === *@
                    var vc = Model.ViewingCommission;
                    var disabled = Model.IsEditing ? "" : "disabled";

                    @if (vc.CustomFieldsJson != null && Model.ViewingTemplateJson != null)
                    {
                        @* Dynamic view/edit for new commissions *@
                        <form method="post" asp-page-handler="UpdateCommission" enctype="multipart/form-data" id="viewForm">
                            <input type="hidden" name="CommissionId" value="@vc.Id" />
                            <div class="form">
                                <div class="fhead">
                                    <h1>Commission Details</h1>
                                    <p>Status: <strong>@vc.Status</strong> — Submitted @vc.DateSubmitted.ToString("d MMM yyyy") at @vc.TimeSubmitted</p>
                                </div>
                                <div id="dynamicViewForm"></div>
                                @if (Model.IsEditing)
                                {
                                    <input type="hidden" name="CustomFieldsJson" id="editCustomFieldsJson">
                                    <input type="hidden" name="FormTemplateVersion" value="@vc.FormTemplateVersion">
                                    <div style="padding:15px 25px; display:flex; justify-content:flex-end;"><button type="submit" class="submit">Save Changes</button></div>
                                }
                                @if (vc.Status == "Completed" && !string.IsNullOrEmpty(vc.FinalOutputPath))
                                {
                                    <div class="cont" style="margin-top:15px;">
                                        <h1>Final Output</h1>
                                        <div class="inputs">
                                            <div class="input">
                                                <p>Final Output Image</p>
                                                <div style="display:flex; align-items:center; gap:10px;">
                                                    <div class="text" style="cursor:pointer; flex:1;" onclick="showImagePreviewUrl('@vc.FinalOutputPath')">
                                                        <span class="placeholder">@System.IO.Path.GetFileName(vc.FinalOutputPath)</span>
                                                    </div>
                                                    <a href="@vc.FinalOutputPath" download style="background:none; border:none; cursor:pointer; display:flex; align-items:center; text-decoration:none;">
                                                        <span class="material-symbols-rounded" style="font-size:1.8rem; color:#1b1b1b;">download</span>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </form>
                    }
                    else
                    {
                    @* Hardcoded view/edit for old commissions *@
                    <form method="post" asp-page-handler="UpdateCommission" enctype="multipart/form-data" id="viewForm">
                        <input type="hidden" name="CommissionId" value="@vc.Id" />
                        <div class="form">
                            <div class="fhead">
                                <h1>Commission Details</h1>
                                <p>Status: <strong>@vc.Status</strong> — Submitted @vc.DateSubmitted.ToString("d MMM yyyy") at @vc.TimeSubmitted</p>
                            </div>
                            <div class="cont">
                                <h1>Contact Information</h1>
                                <div class="inputs">
                                    <div class="input">
                                        <p>Email Address</p>
                                        <input type="text" class="box" name="Email" value="@vc.Email" @disabled>
                                    </div>
                                    <div class="input">
                                        <p>Contact Number</p>
                                        <input type="tel" class="box" name="ContactNumber" value="@vc.ContactNumber" @disabled>
                                    </div>
                                    <div class="input">
                                        <p>Social Account Link</p>
                                        <input type="text" class="box" name="SocialAccountLink" value="@vc.SocialAccountLink" @disabled>
                                    </div>
                                </div>
                            </div>
                            <div class="det">
                                <h1>Art Details</h1>
                                <div class="inputs">
                                    <div class="input">
                                        <p>Rush Commission?</p>
                                        <select name="RushCommission" @disabled>
                                            <option value="Yes" @(vc.RushCommission ? "selected" : "")>Yes</option>
                                            <option value="No" @(!vc.RushCommission ? "selected" : "")>No</option>
                                        </select>
                                    </div>
                                    <div class="input">
                                        <p>Subject</p>
                                        <input type="text" class="box" name="Subject" value="@vc.Subject" @disabled>
                                    </div>
                                    <div class="input">
                                        <p>Character Sheet</p>
                                        @if (Model.IsEditing)
                                        {
                                            <div class="text edit-file-label" data-filepath="@vc.CharacterSheetPath" style="position:relative; cursor:pointer;">
                                                <span class="placeholder">@(string.IsNullOrEmpty(vc.CharacterSheetPath) ? "No file uploaded" : System.IO.Path.GetFileName(vc.CharacterSheetPath))</span>
                                                <span class="material-symbols-rounded">upload</span>
                                            </div>
                                            <input type="file" accept="image/jpeg, image/png" class="file" name="CharacterSheet">
                                        }
                                        else
                                        {
                                            <input type="text" class="box" value="@(string.IsNullOrEmpty(vc.CharacterSheetPath) ? "No file uploaded" : System.IO.Path.GetFileName(vc.CharacterSheetPath))" disabled>
                                        }
                                    </div>
                                    <div class="input">
                                        <p>Character Reference</p>
                                        <input type="text" class="box" name="CharacterReference" value="@vc.CharacterReference" @disabled>
                                    </div>
                                    <p>Commission Type</p>
                                    <div class="comwrap">
                                        <div class="input">
                                            <select name="CommissionType1" @disabled>
                                                <option value="Icon" @(vc.CommissionType1 == "Icon" ? "selected" : "")>Icon</option>
                                                <option value="Bust-Up" @(vc.CommissionType1 == "Bust-Up" ? "selected" : "")>Bust-Up</option>
                                                <option value="Half Body" @(vc.CommissionType1 == "Half Body" ? "selected" : "")>Half Body</option>
                                                <option value="Whole Body" @(vc.CommissionType1 == "Whole Body" ? "selected" : "")>Whole Body</option>
                                            </select>
                                        </div>
                                        <div class="input">
                                            <select name="CommissionType2" @disabled>
                                                <option value="One Person" @(vc.CommissionType2 == "One Person" ? "selected" : "")>One Person</option>
                                                <option value="Two" @(vc.CommissionType2 == "Two" ? "selected" : "")>Two</option>
                                                <option value="Three" @(vc.CommissionType2 == "Three" ? "selected" : "")>Three</option>
                                                <option value="More" @(vc.CommissionType2 == "More" ? "selected" : "")>More</option>
                                            </select>
                                        </div>
                                        <div class="input">
                                            <select name="CommissionType3" @disabled>
                                                <option value="Sketch" @(vc.CommissionType3 == "Sketch" ? "selected" : "")>Sketch</option>
                                                <option value="Fully Rendered" @(vc.CommissionType3 == "Fully Rendered" ? "selected" : "")>Fully Rendered</option>
                                                <option value="Chibi" @(vc.CommissionType3 == "Chibi" ? "selected" : "")>Chibi</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="input">
                                        <p>Reference Pose</p>
                                        @if (Model.IsEditing)
                                        {
                                            <div class="text edit-file-label" data-filepath="@vc.ReferencePosePath" style="position:relative; cursor:pointer;">
                                                <span class="placeholder">@(string.IsNullOrEmpty(vc.ReferencePosePath) ? "No file" : System.IO.Path.GetFileName(vc.ReferencePosePath))</span>
                                                <span class="material-symbols-rounded">upload</span>
                                            </div>
                                            <input type="file" accept="image/jpeg, image/png" class="file" name="ReferencePose">
                                        }
                                        else
                                        {
                                            <input type="text" class="box" value="@(string.IsNullOrEmpty(vc.ReferencePosePath) ? "No file" : System.IO.Path.GetFileName(vc.ReferencePosePath))" disabled>
                                        }
                                    </div>
                                    <div class="input">
                                        <p>Reference Background</p>
                                        @if (Model.IsEditing)
                                        {
                                            <div class="text edit-file-label" data-filepath="@vc.ReferenceBackgroundPath" style="position:relative; cursor:pointer;">
                                                <span class="placeholder">@(string.IsNullOrEmpty(vc.ReferenceBackgroundPath) ? "No file uploaded" : System.IO.Path.GetFileName(vc.ReferenceBackgroundPath))</span>
                                                <span class="material-symbols-rounded">upload</span>
                                            </div>
                                            <input type="file" accept="image/jpeg, image/png" class="file" name="ReferenceBackground">
                                        }
                                        else
                                        {
                                            <input type="text" class="box" value="@(string.IsNullOrEmpty(vc.ReferenceBackgroundPath) ? "No file uploaded" : System.IO.Path.GetFileName(vc.ReferenceBackgroundPath))" disabled>
                                        }
                                    </div>
                                    <div class="input">
                                        <p>Canvas Size</p>
                                        @if (Model.IsEditing)
                                        {
                                            <select name="CanvasSize" id="editCanvasSize">
                                                <option value="1080x1080" @(vc.CanvasSize == "1080x1080" ? "selected" : "")>1080 x 1080</option>
                                                <option value="1920x1080" @(vc.CanvasSize == "1920x1080" ? "selected" : "")>1920 x 1080</option>
                                                <option value="2480x3508" @(vc.CanvasSize == "2480x3508" ? "selected" : "")>2480 x 3508 (A4)</option>
                                                <option value="3508x2480" @(vc.CanvasSize == "3508x2480" ? "selected" : "")>3508 x 2480 (A4 Landscape)</option>
                                                <option value="4000x4000" @(vc.CanvasSize == "4000x4000" ? "selected" : "")>4000 x 4000</option>
                                                <option value="Other" @(new[]{"1080x1080","1920x1080","2480x3508","3508x2480","4000x4000"}.Contains(vc.CanvasSize) ? "" : "selected")>Other</option>
                                            </select>
                                        }
                                        else
                                        {
                                            <input type="text" class="box" value="@vc.CanvasSize" disabled>
                                        }
                                    </div>
                                    @if (Model.IsEditing)
                                    {
                                        var isCustom = !new[]{"1080x1080","1920x1080","2480x3508","3508x2480","4000x4000"}.Contains(vc.CanvasSize);
                                        <div class="input" id="editCustomCanvas" style="display: @(isCustom ? "flex" : "none");">
                                            <p>Custom Canvas Size</p>
                                            <input type="text" class="box" name="CustomCanvasSize" value="@(isCustom ? vc.CanvasSize : "")">
                                        </div>
                                    }
                                    <div class="input">
                                        <p>Other Notes</p>
                                        <textarea class="box" name="OtherNotes" rows="4" style="resize: vertical; min-height: 80px;" @disabled>@vc.OtherNotes</textarea>
                                    </div>
                                </div>
                            </div>
                            <div class="mop">
                                <h1>Mode of Payment</h1>
                                <div class="inputs">
                                    <div class="input">
                                        <p>Payment Method</p>
                                        <select name="ModeOfPayment" @disabled>
                                            <option value="GCash" @(vc.ModeOfPayment == "GCash" ? "selected" : "")>GCash</option>
                                            <option value="PayMaya" @(vc.ModeOfPayment == "PayMaya" ? "selected" : "")>PayMaya</option>
                                            <option value="Game Credits" @(vc.ModeOfPayment == "Game Credits" ? "selected" : "")>Game Credits</option>
                                        </select>
                                    </div>
                                    <div class="input">
                                        <p>Estimated Budget</p>
                                        <input type="text" class="box" name="EstimatedBudget" value="@vc.EstimatedBudget" @disabled>
                                    </div>
                                </div>

                                @* === FINAL OUTPUT (Completed) === *@
                                @if (vc.Status == "Completed" && !string.IsNullOrEmpty(vc.FinalOutputPath))
                                {
                                    <div class="cont">
                                        <h1>Final Output</h1>
                                        <div class="inputs">
                                            <div class="input">
                                                <p>Final Output Image</p>
                                                <div style="display:flex; align-items:center; gap:10px;">
                                                    <div class="text" style="cursor:pointer; flex:1;" onclick="showImagePreviewUrl('@vc.FinalOutputPath')">
                                                        <span class="placeholder">@System.IO.Path.GetFileName(vc.FinalOutputPath)</span>
                                                    </div>
                                                    <a href="@vc.FinalOutputPath" download style="background:none; border:none; cursor:pointer; display:flex; align-items:center; text-decoration:none;">
                                                        <span class="material-symbols-rounded" style="font-size:1.8rem; color:#1b1b1b;">download</span>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            @if (Model.IsEditing)
                            {
                                <div style="padding:15px 25px; display:flex; justify-content:flex-end;"><button type="submit" class="submit">Save Changes</button></div>
                            }
                        </div>
                    </form>
                    }
                }

                @* === NEW COMMISSION FORM (DYNAMIC) === *@
                <form method="post" asp-page="/Commission" enctype="multipart/form-data" id="formContent" style="display: none;">
                    <div class="form" id="dynamicForm"></div>
                    <input type="hidden" name="CustomFieldsJson" id="customFieldsJson">
                    <input type="hidden" name="FormTemplateVersion" value="@Model.CurrentTemplateVersion">
                    <div class="form" style="padding:0 25px 25px 25px;">
                        <button type="submit" class="submit">Submit Commission</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="footer">
        <p>&copy; Art Online, 2026. All rights reserved.</p>
        <div class="cont">
            <p>Connect w/ Developers:</p>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
            </svg>
            <a href="">developers@@gmail.com</a>
        </div>
    </div>

<script>

    // === DYNAMIC FORM RENDERING ===
    let templateFields = @Html.Raw(Model.CurrentTemplateJson);

    function renderNewCommissionForm() {
        const container = document.getElementById('dynamicForm');
        if (!container) return;
        let html = '';
        let inSection = false;

        templateFields.forEach(field => {
            switch(field.type) {
                case 'mainheader':
                    html += `<div class="fhead"><h1>${field.title}</h1><p>${field.description}</p></div>`;
                    break;
                case 'subheader':
                    if (inSection) html += '</div></div>';
                    html += `<div class="cont"><h1>${field.label}</h1><div class="inputs">`;
                    inSection = true;
                    break;
                case 'text':
                    html += `<div class="input"><p>${field.label}${field.required ? ' <span style="color:red;">*</span>' : ''}</p><input type="text" class="box" name="field_${field.id}" placeholder="${field.placeholder || ''}" ${field.required ? 'required' : ''}></div>`;
                    break;
                case 'file':
                    html += `<div class="input"><p>${field.label}${field.required ? ' <span style="color:red;">*</span>' : ''}</p><label class="text" style="cursor:pointer;"><span class="placeholder">Upload image (JPEG/PNG)</span><span class="material-symbols-rounded">upload</span></label><input type="file" accept="image/jpeg,image/png" class="file" name="file_${field.id}"></div>`;
                    break;
                case 'dropdown':
                    const opts = (field.options || []).map(o => `<option value="${o}">${o}</option>`).join('');
                    html += `<div class="input"><p>${field.label}${field.required ? ' <span style="color:red;">*</span>' : ''}</p><select name="field_${field.id}" ${field.required ? 'required' : ''}><option value="">-- Select --</option>${opts}</select></div>`;
                    break;
                case 'textarea':
                    html += `<div class="input"><p>${field.label}${field.required ? ' <span style="color:red;">*</span>' : ''}</p><textarea class="box" name="field_${field.id}" placeholder="${field.placeholder || ''}" style="height:80px;resize:none;" ${field.required ? 'required' : ''}></textarea></div>`;
                    break;
            }
        });
        if (inSection) html += '</div></div>';
        container.innerHTML = html;

        // Re-attach file label click handlers
        container.querySelectorAll('label.text').forEach(label => {
            const placeholder = label.querySelector('.placeholder');
            if (placeholder) label.dataset.original = placeholder.textContent;
            label.style.position = 'relative';
            label.addEventListener('click', (e) => {
                // Don't trigger file picker if clicking the X button
                if (e.target.closest('.remove-file')) return;
                e.preventDefault();
                e.stopPropagation();
                const fileInput = label.nextElementSibling;
                if (fileInput && fileInput.type === 'file') {
                    // If file already attached, show preview popup
                    if (fileInput.files && fileInput.files.length > 0) {
                        showImagePreview(fileInput.files[0]);
                    } else {
                        fileInput.click();
                    }
                }
            });
        });
        container.querySelectorAll('.file').forEach(input => {
            input.addEventListener('change', function() {
                const label = this.previousElementSibling;
                if (label) {
                    const placeholder = label.querySelector('.placeholder');
                    if (placeholder && this.files.length > 0) {
                        placeholder.textContent = this.files[0].name;
                        // Add X remove button
                        let removeBtn = label.querySelector('.remove-file');
                        if (!removeBtn) {
                            removeBtn = document.createElement('button');
                            removeBtn.type = 'button';
                            removeBtn.className = 'remove-file';
                            removeBtn.textContent = '✕';
                            removeBtn.style.cssText = 'position:absolute; top:8px; right:10px; background:none; border:none; color:#9e3e3e; font-weight:700; font-size:1.2rem; cursor:pointer; z-index:5;';
                            label.appendChild(removeBtn);
                            removeBtn.addEventListener('click', (e) => {
                                e.stopPropagation();
                                e.preventDefault();
                                input.value = '';
                                placeholder.textContent = label.dataset.original || 'Upload image (JPEG/PNG)';
                                removeBtn.remove();
                            });
                        }
                    }
                }
            });
        });
    }

    // Image preview popup
    function showImagePreview(file) {
        if (document.querySelector('.img-preview-overlay')) return;
        const reader = new FileReader();
        reader.onload = (e) => {
            const overlay = document.createElement('div');
            overlay.className = 'img-preview-overlay';
            overlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:999999; display:flex; justify-content:center; align-items:center; cursor:pointer;';
            const img = document.createElement('img');
            img.src = e.target.result;
            img.style.cssText = 'max-width:90%; max-height:90%; object-fit:contain; border-radius:8px;';
            overlay.appendChild(img);
            overlay.addEventListener('click', (ev) => { ev.stopPropagation(); overlay.remove(); });
            document.body.appendChild(overlay);
        };
        reader.readAsDataURL(file);
    }

    // Render the form on page load
    renderNewCommissionForm();

    // === DYNAMIC VIEW/EDIT for commissions with CustomFieldsJson ===
    const viewingTemplateRaw = @Html.Raw(Model.ViewingTemplateJson != null ? Model.ViewingTemplateJson : "null");
    const viewingValuesRaw = @Html.Raw(Model.ViewingCommission?.CustomFieldsJson ?? "null");
    const vcStatus = '@(Model.ViewingCommission?.Status ?? "")';
    const vcDate = '@(Model.ViewingCommission?.DateSubmitted.ToString("d MMM yyyy") ?? "")';
    const vcTime = '@(Model.ViewingCommission?.TimeSubmitted ?? "")';
    const isEditMode = @(Model.IsEditing ? "true" : "false");

    if (viewingTemplateRaw && viewingValuesRaw) {
        const viewTemplate = typeof viewingTemplateRaw === 'string' ? JSON.parse(viewingTemplateRaw) : viewingTemplateRaw;
        const viewValues = typeof viewingValuesRaw === 'string' ? JSON.parse(viewingValuesRaw) : viewingValuesRaw;
        renderDynamicViewForm(viewTemplate, viewValues, isEditMode);
    }

    function renderDynamicViewForm(fields, values, editable) {
        const container = document.getElementById('dynamicViewForm');
        if (!container) return;
        let html = '';
        let inSection = false;

        fields.forEach(field => {
            const val = values['field_' + field.id] || '';
            const filePath = values['file_' + field.id] || '';
            const disabled = editable ? '' : 'disabled';

            switch(field.type) {
                case 'mainheader':
                    break;
                case 'subheader':
                    if (inSection) html += '</div></div>';
                    html += `<div class="cont"><h1>${field.label}</h1><div class="inputs">`;
                    inSection = true;
                    break;
                case 'text':
                    html += `<div class="input"><p>${field.label}</p><input type="text" class="box" name="field_${field.id}" value="${val.replace(/"/g, '&quot;')}" ${disabled}></div>`;
                    break;
                case 'file':
                    const hasFile = filePath && filePath !== '';
                    const fileName = hasFile ? filePath.split('/').pop() : 'No file';
                    if (editable) {
                        html += `<div class="input"><p>${field.label}</p><div class="text edit-file-label" data-filepath="${filePath}" style="position:relative; cursor:pointer;"><span class="placeholder">${fileName}</span><span class="material-symbols-rounded">upload</span></div><input type="file" accept="image/jpeg,image/png" class="file" name="file_${field.id}"></div>`;
                    } else {
                        if (hasFile) {
                            html += `<div class="input"><p>${field.label}</p><div class="text" style="cursor:pointer; position:relative;" onclick="showImagePreviewUrl('${filePath}')"><span class="placeholder">${fileName}</span></div></div>`;
                        } else {
                            html += `<div class="input"><p>${field.label}</p><input type="text" class="box" value="No file" disabled></div>`;
                        }
                    }
                    break;
                case 'dropdown':
                    if (editable) {
                        const opts = (field.options || []).map(o => `<option value="${o}" ${o === val ? 'selected' : ''}>${o}</option>`).join('');
                        html += `<div class="input"><p>${field.label}</p><select name="field_${field.id}"><option value="">-- Select --</option>${opts}</select></div>`;
                    } else {
                        html += `<div class="input"><p>${field.label}</p><select disabled><option selected>${val || '—'}</option></select></div>`;
                    }
                    break;
                case 'textarea':
                    html += `<div class="input"><p>${field.label}</p><textarea class="box" name="field_${field.id}" style="height:80px;resize:none;" ${disabled}>${val}</textarea></div>`;
                    break;
            }
        });
        if (inSection) html += '</div></div>';
        container.innerHTML = html;

        // If editable, attach file handlers for edit-file-label elements
        if (editable) {
            container.querySelectorAll('.edit-file-label').forEach(label => {
                const placeholder = label.querySelector('.placeholder');
                const fileInput = label.nextElementSibling;
                const originalPath = label.dataset.filepath || '';
                const originalName = placeholder ? placeholder.textContent : '';
                const hasOriginalFile = originalPath && originalPath !== '' && originalName !== 'No file';
                let state = hasOriginalFile ? 'original' : 'empty';

                function addXBtn(onRemove) {
                    let btn = label.querySelector('.remove-file');
                    if (btn) btn.remove();
                    btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'remove-file';
                    btn.textContent = '✕';
                    btn.style.cssText = 'position:absolute; top:8px; right:10px; background:none; border:none; color:#9e3e3e; font-weight:700; font-size:1.2rem; cursor:pointer; z-index:5;';
                    label.appendChild(btn);
                    btn.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); onRemove(); });
                }
                function setOriginal() { state='original'; if(fileInput)fileInput.value=''; if(placeholder)placeholder.textContent=originalName; label.dataset.filepath=originalPath; addXBtn(()=>setEmpty()); }
                function setEmpty() { state='empty'; if(fileInput)fileInput.value=''; if(placeholder)placeholder.textContent='No file'; label.dataset.filepath=''; let b=label.querySelector('.remove-file'); if(b)b.remove(); }
                function setNew(name) { state='new'; if(placeholder)placeholder.textContent=name; label.dataset.filepath='new'; addXBtn(()=>{ if(hasOriginalFile)setOriginal(); else setEmpty(); }); }

                if (hasOriginalFile) addXBtn(()=>setEmpty());

                label.addEventListener('click', (e) => {
                    if (e.target.closest('.remove-file')) return;
                    e.preventDefault(); e.stopPropagation();
                    if (state==='new' && fileInput && fileInput.files && fileInput.files.length>0) showImagePreview(fileInput.files[0]);
                    else if (state==='original' && originalPath) showImagePreviewUrl(originalPath);
                    else { if(fileInput)fileInput.click(); }
                });

                if (fileInput) {
                    fileInput.addEventListener('change', function() { if(this.files.length>0) setNew(this.files[0].name); });
                }
            });

            // On form submit, collect field values for CustomFieldsJson
            const viewForm = document.getElementById('viewForm');
            if (viewForm) {
                viewForm.addEventListener('submit', function() {
                    const fields = {};
                    container.querySelectorAll('[name^="field_"]').forEach(el => { fields[el.name] = el.value; });
                    // Keep existing file paths
                    container.querySelectorAll('.edit-file-label').forEach(l => {
                        const fp = l.dataset.filepath;
                        const name = l.nextElementSibling?.name;
                        if (fp && fp !== '' && fp !== 'new' && name) fields[name] = fp;
                    });
                    const hiddenInput = document.getElementById('editCustomFieldsJson');
                    if (hiddenInput) hiddenInput.value = JSON.stringify(fields);
                });
            }
        }
    }

    // On form submit, collect all field values into JSON
    const formContent = document.getElementById('formContent');
    if (formContent) {
        formContent.addEventListener('submit', function(e) {
            const fields = {};
            this.querySelectorAll('[name^="field_"]').forEach(el => {
                fields[el.name] = el.value;
            });
            document.getElementById('customFieldsJson').value = JSON.stringify(fields);
        });
    }

    // Commission filter icons
    const filterProgress = document.getElementById('filterProgress');
    const filterCheck = document.getElementById('filterCheck');
    let progressState = 0; // 0=default(all pending+working), 1=pending only(red), 2=working only(orange)
    let checkState = 0; // 0=default(hidden completed), 1=show completed only(green)

    // Save/restore filter state across navigation
    function saveFilterState() {
        const scrollEl = document.querySelector('.queue')?.parentElement;
        sessionStorage.setItem('commFilterProgress', progressState);
        sessionStorage.setItem('commFilterCheck', checkState);
        if (scrollEl) sessionStorage.setItem('commScrollTop', scrollEl.scrollTop);
    }

    function restoreFilterState() {
        const savedProgress = sessionStorage.getItem('commFilterProgress');
        const savedCheck = sessionStorage.getItem('commFilterCheck');
        const savedScroll = sessionStorage.getItem('commScrollTop');
        if (savedProgress !== null) {
            progressState = parseInt(savedProgress);
            if (progressState === 1) filterProgress.style.color = '#9e3e3e';
            else if (progressState === 2) filterProgress.style.color = '#d4890a';
            else filterProgress.style.color = '';
        }
        if (savedCheck !== null) {
            checkState = parseInt(savedCheck);
            filterCheck.style.color = checkState === 1 ? '#3e9e3e' : '';
        }
        applyFilter();
        if (savedScroll !== null) {
            const scrollEl = document.querySelector('.queue')?.parentElement;
            if (scrollEl) setTimeout(() => { scrollEl.scrollTop = parseInt(savedScroll); }, 50);
        }
    }

    function applyFilter() {
        const queues = document.querySelectorAll('.queue[data-status]');
        queues.forEach(q => {
            const status = q.dataset.status;
            if (checkState === 1) {
                // Check is active: only show completed
                q.style.display = status === 'Completed' ? 'flex' : 'none';
            } else {
                // Progress filter active
                if (progressState === 0) {
                    // Default: show pending + working
                    q.style.display = (status === 'Pending' || status === 'Working') ? 'flex' : 'none';
                } else if (progressState === 1) {
                    // Red: pending only
                    q.style.display = status === 'Pending' ? 'flex' : 'none';
                } else if (progressState === 2) {
                    // Orange: working only
                    q.style.display = status === 'Working' ? 'flex' : 'none';
                }
            }
        });
    }

    filterProgress.addEventListener('click', (e) => {
        e.stopPropagation();
        // Reset check filter
        checkState = 0;
        filterCheck.style.color = '';
        // Cycle progress: default -> red(pending) -> orange(working) -> default
        progressState = (progressState + 1) % 3;
        if (progressState === 0) filterProgress.style.color = '';
        else if (progressState === 1) filterProgress.style.color = '#9e3e3e';
        else if (progressState === 2) filterProgress.style.color = '#d4890a';
        applyFilter();
    });

    filterCheck.addEventListener('click', (e) => {
        e.stopPropagation();
        // Reset progress filter
        progressState = 0;
        filterProgress.style.color = '';
        // Toggle check: default -> green(completed) -> default
        checkState = checkState === 0 ? 1 : 0;
        filterCheck.style.color = checkState === 1 ? '#3e9e3e' : '';
        applyFilter();
    });

    // Restore filter state or apply default
    restoreFilterState();

    // Toggle new form visibility (hides viewing commission when + is clicked)
    document.getElementById('toggleFormBtn').addEventListener('click', async () => {
        const form = document.getElementById('formContent');
        const viewForm = document.getElementById('viewForm');
        // Hide edit button
        const editBtn = document.querySelector('.divh a[href*="edit=true"]');
        if (editBtn) editBtn.style.display = 'none';
        if (viewForm) viewForm.style.display = 'none';
        if (form.style.display === 'none') {
            // Fetch latest template from server (no reload needed)
            try {
                const resp = await fetch('/Commission?handler=Template');
                const data = await resp.json();
                templateFields = JSON.parse(data.fields);
                document.querySelector('input[name="FormTemplateVersion"]').value = data.version;
                renderNewCommissionForm();
            } catch(e) { console.error('Failed to fetch template', e); }
            form.style.display = 'block';
            // Clear the chat when opening new form
            const chatArea = document.getElementById('chatArea');
            if (chatArea) chatArea.innerHTML = '';
            const chatInput = document.querySelector('.chat-input-area');
            if (chatInput) chatInput.style.display = 'none';
        } else {
            form.style.display = 'none';
        }
    });

    // Contact number: only accept numeric input
    const contactNum = document.getElementById('contactNumber');
    if (contactNum) {
        contactNum.addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });
    }

    // Canvas size: show custom input when "Other" is selected (new form)
    const canvasSelect = document.getElementById('canvasSizeSelect');
    if (canvasSelect) {
        canvasSelect.addEventListener('change', function() {
            const customInput = document.getElementById('customCanvasInput');
            customInput.style.display = this.value === 'Other' ? 'flex' : 'none';
        });
    }

    // Canvas size for edit form
    const editCanvasSelect = document.getElementById('editCanvasSize');
    if (editCanvasSelect) {
        editCanvasSelect.addEventListener('change', function() {
            const customInput = document.getElementById('editCustomCanvas');
            if (customInput) customInput.style.display = this.value === 'Other' ? 'flex' : 'none';
        });
    }

    // File input: show filename in label when file is selected
    document.querySelectorAll('.file').forEach(input => {
        input.addEventListener('change', function() {
            const label = this.previousElementSibling;
            const placeholder = label.querySelector('.placeholder');
            if (this.files.length > 0) {
                placeholder.textContent = this.files[0].name;
                let removeBtn = this.parentElement.querySelector('.remove-file');
                if (!removeBtn) {
                    removeBtn = document.createElement('button');
                    removeBtn.type = 'button';
                    removeBtn.className = 'remove-file';
                    removeBtn.textContent = '✕';
                    removeBtn.style.cssText = 'position:absolute; top:8px; right:10px; background:none; border:none; color:#9e3e3e; font-weight:700; font-size:1.2rem; cursor:pointer; z-index:5;';
                    label.style.position = 'relative';
                    label.appendChild(removeBtn);
                    removeBtn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        input.value = '';
                        placeholder.textContent = label.dataset.original || 'Upload a file';
                        removeBtn.remove();
                    });
                }
            }
        });
    });

    // Make labels clickable to trigger file inputs
    // Only apply to labels OUTSIDE the dynamic form (e.g. view/edit existing commissions)
    // Exclude .edit-file-label which has its own handler
    document.querySelectorAll('#viewForm label.text:not(.edit-file-label)').forEach(label => {
        const placeholder = label.querySelector('.placeholder');
        if (placeholder) label.dataset.original = placeholder.textContent;
        label.style.cursor = 'pointer';
        label.addEventListener('click', (e) => {
            if (e.target.closest('.remove-file')) return;
            const fileInput = label.nextElementSibling;
            if (fileInput && fileInput.type === 'file') {
                fileInput.click();
            }
        });
    });

    // Edit mode file fields (pending commission editing) - X button, preview, discard support
    // Skip elements inside #dynamicViewForm (those have their own handlers attached by renderDynamicViewForm)
    document.querySelectorAll('.edit-file-label').forEach(label => {
        if (label.closest('#dynamicViewForm')) return;
        const placeholder = label.querySelector('.placeholder');
        const fileInput = label.nextElementSibling;
        const originalPath = label.dataset.filepath || '';
        const originalName = placeholder ? placeholder.textContent : '';
        const hasOriginalFile = originalPath && originalPath !== '' && originalName !== 'No file uploaded' && originalName !== 'No file';
        let state = hasOriginalFile ? 'original' : 'empty';

        function addXBtn(onRemove) {
            let btn = label.querySelector('.remove-file');
            if (btn) btn.remove();
            btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'remove-file';
            btn.textContent = '✕';
            btn.style.cssText = 'position:absolute; top:8px; right:10px; background:none; border:none; color:#9e3e3e; font-weight:700; font-size:1.2rem; cursor:pointer; z-index:5;';
            label.appendChild(btn);
            btn.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); onRemove(); });
        }
        function setOriginal() { state='original'; if(fileInput)fileInput.value=''; if(placeholder)placeholder.textContent=originalName; label.dataset.filepath=originalPath; addXBtn(()=>setEmpty()); }
        function setEmpty() { state='empty'; if(fileInput)fileInput.value=''; if(placeholder)placeholder.textContent='No file'; label.dataset.filepath=''; let b=label.querySelector('.remove-file'); if(b)b.remove(); }
        function setNew(name) { state='new'; if(placeholder)placeholder.textContent=name; label.dataset.filepath='new'; addXBtn(()=>{ if(hasOriginalFile)setOriginal(); else setEmpty(); }); }

        if (hasOriginalFile) addXBtn(()=>setEmpty());

        label.addEventListener('click', (e) => {
            if (e.target.closest('.remove-file')) return;
            e.preventDefault(); e.stopPropagation();
            if (state==='new' && fileInput && fileInput.files && fileInput.files.length>0) showImagePreview(fileInput.files[0]);
            else if (state==='original' && originalPath) showImagePreviewUrl(originalPath);
            else { if(fileInput) fileInput.click(); }
        });

        if (fileInput) {
            fileInput.addEventListener('change', function() { if(this.files.length>0) setNew(this.files[0].name); });
        }
    });

    // Show image preview from URL (existing server images)
    function showImagePreviewUrl(url) {
        if (document.querySelector('.img-preview-overlay')) return;
        const overlay = document.createElement('div');
        overlay.className = 'img-preview-overlay';
        overlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:999999; display:flex; justify-content:center; align-items:center; cursor:pointer;';
        const img = document.createElement('img');
        img.src = url;
        img.style.cssText = 'max-width:90%; max-height:90%; object-fit:contain; border-radius:8px;';
        overlay.appendChild(img);
        overlay.addEventListener('click', (ev) => { ev.stopPropagation(); overlay.remove(); });
        document.body.appendChild(overlay);
    }

    // Auto-scroll chat to bottom
    const chatArea = document.getElementById('chatArea');
    if (chatArea) chatArea.scrollTop = chatArea.scrollHeight;

    // Live chat polling - check for new messages every 3 seconds
    let lastMsgId = 0;
    // Get the highest message ID currently displayed
    document.querySelectorAll('#chatArea .chat-msg').forEach(el => {
        const id = parseInt(el.dataset?.msgId || '0');
        if (id > lastMsgId) lastMsgId = id;
    });

    const selectedCommId = @(Model.SelectedCommissionId);
    if (selectedCommId > 0) {
        setInterval(async () => {
            try {
                const resp = await fetch(`/Commission?handler=Messages&commissionId=${selectedCommId}&lastId=${lastMsgId}`);
                const messages = await resp.json();
                if (messages.length > 0) {
                    const chatEl = document.getElementById('chatArea');
                    messages.forEach(msg => {
                        const displayName = msg.isArtist ? 'Amoreivc' : 'You';
                        const bubbleClass = msg.isArtist ? 'artist-msg' : 'user-msg';
                        const div = document.createElement('div');
                        div.className = 'chat-msg';
                        div.dataset.msgId = msg.id;
                        const msgContent = msg.imagePath ? `<div class="bubble ${bubbleClass}" style="cursor:pointer;" onclick="showImagePreviewUrl('${msg.imagePath}')">📷 ${msg.message}</div>` : `<div class="bubble ${bubbleClass}">${msg.message}</div>`;
                        div.innerHTML = `<span class="sender">${displayName}</span>${msgContent}<span class="time">${msg.time}</span>`;
                        chatEl.appendChild(div);
                        lastMsgId = msg.id;
                    });
                    chatEl.scrollTop = chatEl.scrollHeight;
                }
            } catch(e) {}
        }, 3000);
    }
</script>

<!-- Discard Changes Modal (user side - gold button) -->
<div id="discardEditModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:99999; justify-content:center; align-items:center;">
    <div style="background:white; border-radius:12px; padding:20px 25px; min-width:300px; max-width:400px; box-shadow:0 10px 40px rgba(0,0,0,0.3); font-family:'Inter',sans-serif;">
        <p style="font-size:1rem; font-weight:600; color:#1b1b1b; margin-bottom:18px;">Discard Changes?</p>
        <div style="display:flex; justify-content:flex-end; gap:10px;">
            <button onclick="document.getElementById('discardEditModal').style.display='none'" style="padding:6px 20px; border:2px solid #1b1b1b; background:white; border-radius:20px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.85rem;">Cancel</button>
            <button onclick="window.location.href='/Commission?commissionId=@Model.SelectedCommissionId'" style="padding:6px 20px; border:none; background:#DCC863; color:#1b1b1b; border-radius:20px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.85rem;">Discard</button>
        </div>
    </div>
</div>

<script>
    // Handle discard edit - check if form has changes
    function handleDiscardEdit(e) {
        e.preventDefault();
        const form = document.getElementById('viewForm');
        if (!form) { window.location.href = '/Commission?commissionId=@Model.SelectedCommissionId'; return; }
        // Check if any file was changed or any text/select was modified
        const fileChanged = Array.from(form.querySelectorAll('input[type="file"]')).some(f => f.files.length > 0);
        const textChanged = Array.from(form.querySelectorAll('input[type="text"], input[type="tel"], textarea, select')).some(el => {
            return el.dataset.origVal !== undefined && el.value !== el.dataset.origVal;
        });
        const fileRemoved = Array.from(form.querySelectorAll('.edit-file-label')).some(l => {
            return l.dataset.filepath !== l.dataset.origpath;
        });
        const hasChanges = fileChanged || textChanged || fileRemoved;
        if (hasChanges) {
            document.getElementById('discardEditModal').style.display = 'flex';
        } else {
            window.location.href = '/Commission?commissionId=@Model.SelectedCommissionId';
        }
    }

    // Store original values on page load for change detection
    const editForm = document.getElementById('viewForm');
    if (editForm) {
        editForm.querySelectorAll('input[type="text"], input[type="tel"], textarea, select').forEach(el => {
            el.dataset.origVal = el.value;
        });
        editForm.querySelectorAll('.edit-file-label').forEach(l => {
            l.dataset.origpath = l.dataset.filepath || '';
        });
    }
</script>


<!-- Chat Image Confirm Modal -->
<div id="chatImageModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:99999; justify-content:center; align-items:center;">
    <div style="background:white; border-radius:12px; padding:20px 25px; min-width:300px; max-width:400px; box-shadow:0 10px 40px rgba(0,0,0,0.3); font-family:'Inter',sans-serif;">
        <p style="font-size:1rem; font-weight:600; color:#1b1b1b; margin-bottom:8px;">Send Image?</p>
        <p id="chatImageName" style="font-size:0.85rem; color:#555; margin-bottom:18px;"></p>
        <div style="display:flex; justify-content:flex-end; gap:10px;">
            <button onclick="cancelChatImage()" style="padding:6px 20px; border:2px solid #1b1b1b; background:white; border-radius:20px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.85rem;">Cancel</button>
            <button onclick="confirmChatImage()" style="padding:6px 20px; border:none; background:#DCC863; color:#1b1b1b; border-radius:20px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.85rem;">Confirm</button>
        </div>
    </div>
</div>

<script>
    function showChatImageConfirm(input) {
        if (input.files.length > 0) {
            document.getElementById('chatImageName').textContent = input.files[0].name;
            document.getElementById('chatImageModal').style.display = 'flex';
        }
    }
    function cancelChatImage() {
        document.getElementById('chatImageModal').style.display = 'none';
        document.getElementById('chatImageInput').value = '';
    }
    async function confirmChatImage() {
        document.getElementById('chatImageModal').style.display = 'none';
        const input = document.getElementById('chatImageInput');
        if (!input.files.length) return;
        const formData = new FormData();
        formData.append('CommissionId', '@Model.SelectedCommissionId');
        formData.append('file', input.files[0]);
        // Get antiforgery token
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        if (token) formData.append('__RequestVerificationToken', token);
        try {
            const resp = await fetch('/Commission?handler=SendImage', { method: 'POST', body: formData });
            const data = await resp.json();
            if (data.success) {
                const chatEl = document.getElementById('chatArea');
                const div = document.createElement('div');
                div.className = 'chat-msg';
                div.dataset.msgId = data.id;
                div.innerHTML = `<span class="sender">You</span><div class="bubble user-msg" style="cursor:pointer;" onclick="showImagePreviewUrl('${data.imagePath}')">📷 ${data.message}</div><span class="time">${data.time}</span>`;
                chatEl.appendChild(div);
                chatEl.scrollTop = chatEl.scrollHeight;
                lastMsgId = data.id;
            }
        } catch(e) { console.error(e); }
        input.value = '';
    }
</script>

