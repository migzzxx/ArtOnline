@page
@model ArtOnline.Pages.ArtistCommissionModel
@removeTagHelper "Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers"
@using System.IO

<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Artist - Commissions</title>
    <link rel="stylesheet" href="~/css/comm_artistui.css">
</head>

<style>
    .file-preview {
        display: flex; align-items: center;
        transition: background-color 0.2s;
    }
    .file-preview:hover { background-color: #e2e2e2; }
</style>

<body>
    <div class="header">
        <div class="left">
            <img src="~/assets/LOGO 2.png" alt="LOGO-2" border="0">
            <h1>ArtOnline</h1>
        </div>
        <div class="right">
            <a class="dashboard" href="/ArtistDashboard">Dashboard</a>
            <a class="comm" href="/ArtistCommission">Commission</a>
            <a class="form" href="/ArtistForm">Form</a>
            <a class="gallery" href="/ArtistGallery">Gallery</a>
        </div>
    </div>

    <div class="mid">
        <div class="midl">
            <div class="top">
                <div class="divh">
                    <h1>Commissions</h1>
                    <div class="wrap">
                        <span class="material-symbols-rounded" id="filterProgress" style="font-weight: lighter; cursor:pointer;">donut_large</span>
                        <span class="material-symbols-rounded" id="filterCheck" style="font-weight: bold; cursor:pointer;">check</span>
                    </div>
                </div>
                <div style="overflow-y:auto; flex:1; min-height:0;">
                @foreach (var c in Model.AllCommissions)
                {
                    <div class="queue" data-status="@c.Status" style="cursor: pointer;" onclick="saveFilterState(); window.location.href='/ArtistCommission?commissionId=@c.Id'">
                        <div class="pleft" style="background-color: @(c.Status == "Pending" ? "#ec7c7c" : c.Status == "Working" ? "#ecb07c" : "#7cec7c")"></div>
                        <div class="pending">
                            <div class="pmid">
                                <p class="stat" style="color: @(c.Status == "Pending" ? "#9e3e3e" : c.Status == "Working" ? "#9e7a3e" : "#3e9e3e")">[<span>@c.Status</span>]</p>
                                <div class="date">
                                    <p>@c.DateSubmitted.ToString("d MMM")</p>
                                    <p class="dot">●</p>
                                    <p>@c.TimeSubmitted</p>
                                </div>
                            </div>
                            <div class="pright">
                                <p class="name">@c.Subject</p>
                                <div class="attr">
                                    @if (c.RushCommission)
                                    {
                                        <p class="a1" style="font-weight: bold;">Rush</p>
                                        <p class="dot">●</p>
                                    }
                                    <p class="a2">@c.CommissionType1</p>
                                    <p class="dot">●</p>
                                    <p class="a3">@c.CommissionType2</p>
                                    <p class="dot">●</p>
                                    <p class="a4">@c.CommissionType3</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                </div>
            </div>
            <div class="bot">
                <div class="divh">
                    <h1>Chats</h1>
                </div>
                <div class="chats" id="chatArea">
                    <div style="flex:1;"></div>
                    @foreach (var msg in Model.ChatMessages)
                    {
                        var timeDiff = DateTime.Now - msg.SentAt;
                        var timeDisplay = timeDiff.TotalHours < 24 ? msg.SentAt.ToString("h:mm tt") : msg.SentAt.ToString("dd/MM/yyyy");
                        var displayName = msg.IsArtist ? "You" : "@" + Model.CommissionUsername;
                        var bubbleClass = msg.IsArtist ? "self" : "other";
                        <div class="chat @bubbleClass" data-msg-id="@msg.Id">
                            <span class="user">@displayName</span>
                            <div class="bubble">@msg.Message</div>
                            <span class="time">@timeDisplay</span>
                        </div>
                    }
                </div>
                @if (Model.SelectedCommissionId > 0)
                {
                    <form method="post" asp-page-handler="SendMessage" class="input-group">
                        <input type="hidden" name="SelectedCommissionId" value="@Model.SelectedCommissionId" />
                        <input type="text" name="ChatMessageText" placeholder="Type a message..." required />
                        <button type="submit" class="send">
                            <span class="material-symbols-rounded">send</span>
                        </button>
                    </form>
                }
            </div>
        </div>
        <div class="midr">
            <div class="divh">
                <h1>Fill Out Form</h1>
                @if (Model.ViewingCommission != null)
                {
                    var statusColor = Model.ViewingCommission.Status == "Pending" ? "color:rgb(255, 72, 72)" : Model.ViewingCommission.Status == "Working" ? "color:#d4890a" : "color:#3e9e3e";
                    <p>(Status: <span style="@statusColor">@Model.ViewingCommission.Status.ToUpper()</span>)</p>
                }
                else
                {
                    <p>(Select a commission)</p>
                }
                @if (Model.ViewingCommission != null && Model.ViewingCommission.Status != "Completed")
                {
                    <div style="position:absolute; right:15px; display:flex; align-items:center;">
                        <form method="post" asp-page-handler="UpdateStatus" style="display:inline;" id="statusForm">
                            <input type="hidden" name="CommissionId" value="@Model.ViewingCommission.Id" />
                            @if (Model.ViewingCommission.Status == "Pending")
                            {
                                <input type="hidden" name="NewStatus" value="Working" />
                                <button type="button" onclick="showStatusModal('Working')" style="background:none; border:none; cursor:pointer; display:flex; align-items:center;" title="Change to Working">
                                    <span class="material-symbols-rounded" style="font-size:1.8rem;">edit</span>
                                </button>
                            }
                            else if (Model.ViewingCommission.Status == "Working")
                            {
                                <input type="hidden" name="NewStatus" value="Completed" />
                                <button type="button" onclick="showStatusModal('Completed')" style="background:none; border:none; cursor:pointer; display:flex; align-items:center;" title="Change to Completed">
                                    <span class="material-symbols-rounded" style="font-size:1.8rem;">edit</span>
                                </button>
                            }
                        </form>
                    </div>
                }
            </div>
            <div class="wrap">
                @if (Model.ViewingCommission != null)
                {
                    var vc = Model.ViewingCommission;
                    <div class="form">
                        <div class="fhead">
                            <h1>Commission Details</h1>
                            <p>Submitted commission form from client.</p>
                        </div>

                        <div class="commission">
                            <p class="cid">
                                <span class="label">Commission ID</span>
                                <span class="colon">:</span>
                                <span class="value">COM-@vc.Id</span>
                            </p>
                            <p>
                                <span class="label">Username</span>
                                <span class="colon">:</span>
                                <span class="value">@Model.CommissionUsername</span>
                            </p>
                            <p>
                                <span class="label">First Name</span>
                                <span class="colon">:</span>
                                <span class="value">@(vc.User?.FirstName ?? "")</span>
                            </p>
                            <p>
                                <span class="label">Last Name</span>
                                <span class="colon">:</span>
                                <span class="value">@(vc.User?.LastName ?? "")</span>
                            </p>
                            <p>
                                <span class="label">Email Address</span>
                                <span class="colon">:</span>
                                <span class="value">@vc.Email</span>
                            </p>
                            <p>
                                <span class="label">Time Submitted</span>
                                <span class="colon">:</span>
                                <span class="value">@vc.TimeSubmitted</span>
                            </p>
                            <p>
                                <span class="label">Date Submitted</span>
                                <span class="colon">:</span>
                                <span class="value">@vc.DateSubmitted.ToString("MMMM dd, yyyy")</span>
                            </p>
                        </div>

                        <div class="cont">
                            <h1>Contact Information</h1>
                            <div class="inputs">
                                <div class="input">
                                    <p>Email Address</p>
                                    <input type="text" class="box" value="@vc.Email" disabled>
                                </div>
                                <div class="input">
                                    <p>Contact Number</p>
                                    <input type="text" class="box" value="@vc.ContactNumber" disabled>
                                </div>
                                <div class="input">
                                    <p>Social Account Link</p>
                                    <input type="text" class="box" value="@vc.SocialAccountLink" disabled>
                                </div>
                            </div>
                        </div>
                        <div class="det">
                            <h1>Art Details</h1>
                            <div class="inputs">
                                <div class="input">
                                    <p>Rush Commission?</p>
                                    <input type="text" class="box" value="@(vc.RushCommission ? "Yes" : "No")" disabled>
                                </div>
                                <div class="input">
                                    <p>Subject</p>
                                    <input type="text" class="box" value="@vc.Subject" disabled>
                                </div>
                                <div class="input">
                                    <p>Character Sheet</p>
                                    @if (!string.IsNullOrEmpty(vc.CharacterSheetPath))
                                    {
                                        <div class="box file-preview" style="cursor:pointer;" onclick="showImagePreviewUrl('@vc.CharacterSheetPath')">@System.IO.Path.GetFileName(vc.CharacterSheetPath)</div>
                                    }
                                    else
                                    {
                                        <input type="text" class="box" value="No file uploaded" disabled>
                                    }
                                </div>
                                <div class="input">
                                    <p>Character Reference</p>
                                    <input type="text" class="box" value="@(string.IsNullOrWhiteSpace(vc.CharacterReference) ? "None provided" : vc.CharacterReference)" disabled>
                                </div>
                                <p>Commission Type</p>
                                <div class="comwrap">
                                    <div class="input">
                                        <input type="text" class="box" value="@vc.CommissionType1" disabled>
                                    </div>
                                    <div class="input">
                                        <input type="text" class="box" value="@vc.CommissionType2" disabled>
                                    </div>
                                    <div class="input">
                                        <input type="text" class="box" value="@vc.CommissionType3" disabled>
                                    </div>
                                </div>
                                <div class="input">
                                    <p>Reference Pose</p>
                                    @if (!string.IsNullOrEmpty(vc.ReferencePosePath))
                                    {
                                        <div class="box file-preview" style="cursor:pointer;" onclick="showImagePreviewUrl('@vc.ReferencePosePath')">@System.IO.Path.GetFileName(vc.ReferencePosePath)</div>
                                    }
                                    else
                                    {
                                        <input type="text" class="box" value="No file" disabled>
                                    }
                                </div>
                                <div class="input">
                                    <p>Reference Background</p>
                                    @if (!string.IsNullOrEmpty(vc.ReferenceBackgroundPath))
                                    {
                                        <div class="box file-preview" style="cursor:pointer;" onclick="showImagePreviewUrl('@vc.ReferenceBackgroundPath')">@System.IO.Path.GetFileName(vc.ReferenceBackgroundPath)</div>
                                    }
                                    else
                                    {
                                        <input type="text" class="box" value="No file uploaded" disabled>
                                    }
                                </div>
                                <div class="input">
                                    <p>Canvas Size</p>
                                    <input type="text" class="box" value="@vc.CanvasSize" disabled>
                                </div>
                                <div class="input">
                                    <p>Other Notes</p>
                                    <input type="text" class="box" value="@(string.IsNullOrWhiteSpace(vc.OtherNotes) ? "None" : vc.OtherNotes)" disabled>
                                </div>
                            </div>
                        </div>
                        <div class="mop">
                            <h1>Mode of Payment</h1>
                            <div class="inputs">
                                <div class="input">
                                    <p>Payment Method</p>
                                    <input type="text" class="box" value="@vc.ModeOfPayment" disabled>
                                </div>
                                <div class="input">
                                    <p>Estimated Budget</p>
                                    <input type="text" class="box" value="@vc.EstimatedBudget" disabled>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="footer">
        <p>&copy; Art Online, 2026. All rights reserved.</p>
        <div class="cont">
            <p>Connect w/ Developers:</p>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
            </svg>
            <a href="">developers&#64;gmail.com</a>
        </div>
    </div>

<script>
    // Image preview popup
    function showImagePreviewUrl(url) {
        if (document.querySelector('.img-preview-overlay')) return;
        const overlay = document.createElement('div');
        overlay.className = 'img-preview-overlay';
        overlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:999999; display:flex; justify-content:center; align-items:center; cursor:pointer;';
        const img = document.createElement('img');
        img.src = url;
        img.style.cssText = 'max-width:90%; max-height:90%; object-fit:contain; border-radius:8px;';
        overlay.appendChild(img);
        overlay.addEventListener('click', (ev) => { ev.stopPropagation(); overlay.remove(); });
        document.body.appendChild(overlay);
    }

    // Commission filter icons
    const filterProgress = document.getElementById('filterProgress');
    const filterCheck = document.getElementById('filterCheck');
    let progressState = 0;
    let checkState = 0;

    function saveFilterState() {
        const scrollEl = document.querySelector('.queue')?.parentElement;
        sessionStorage.setItem('artistFilterProgress', progressState);
        sessionStorage.setItem('artistFilterCheck', checkState);
        if (scrollEl) sessionStorage.setItem('artistScrollTop', scrollEl.scrollTop);
    }

    function restoreFilterState() {
        const savedProgress = sessionStorage.getItem('artistFilterProgress');
        const savedCheck = sessionStorage.getItem('artistFilterCheck');
        const savedScroll = sessionStorage.getItem('artistScrollTop');
        if (savedProgress !== null) {
            progressState = parseInt(savedProgress);
            if (progressState === 1) filterProgress.style.color = '#9e3e3e';
            else if (progressState === 2) filterProgress.style.color = '#d4890a';
            else filterProgress.style.color = '';
        }
        if (savedCheck !== null) {
            checkState = parseInt(savedCheck);
            filterCheck.style.color = checkState === 1 ? '#3e9e3e' : '';
        }
        applyFilter();
        if (savedScroll !== null) {
            const scrollEl = document.querySelector('.queue')?.parentElement;
            if (scrollEl) setTimeout(() => { scrollEl.scrollTop = parseInt(savedScroll); }, 50);
        }
    }

    function applyFilter() {
        const queues = document.querySelectorAll('.queue[data-status]');
        queues.forEach(q => {
            const status = q.dataset.status;
            if (checkState === 1) {
                q.style.display = status === 'Completed' ? 'flex' : 'none';
            } else {
                if (progressState === 0) {
                    q.style.display = (status === 'Pending' || status === 'Working') ? 'flex' : 'none';
                } else if (progressState === 1) {
                    q.style.display = status === 'Pending' ? 'flex' : 'none';
                } else if (progressState === 2) {
                    q.style.display = status === 'Working' ? 'flex' : 'none';
                }
            }
        });
    }

    filterProgress.addEventListener('click', (e) => {
        e.stopPropagation();
        checkState = 0;
        filterCheck.style.color = '';
        progressState = (progressState + 1) % 3;
        if (progressState === 0) filterProgress.style.color = '';
        else if (progressState === 1) filterProgress.style.color = '#9e3e3e';
        else if (progressState === 2) filterProgress.style.color = '#d4890a';
        applyFilter();
    });

    filterCheck.addEventListener('click', (e) => {
        e.stopPropagation();
        progressState = 0;
        filterProgress.style.color = '';
        checkState = checkState === 0 ? 1 : 0;
        filterCheck.style.color = checkState === 1 ? '#3e9e3e' : '';
        applyFilter();
    });

    restoreFilterState();

    // Auto-scroll chat to bottom
    const chatArea = document.getElementById('chatArea');
    if (chatArea) chatArea.scrollTop = chatArea.scrollHeight;

    // Live chat polling - check for new messages every 3 seconds
    let lastMsgId = 0;
    document.querySelectorAll('#chatArea .chat').forEach(el => {
        const id = parseInt(el.dataset?.msgId || '0');
        if (id > lastMsgId) lastMsgId = id;
    });

    const selectedCommId = @(Model.SelectedCommissionId);
    if (selectedCommId > 0) {
        setInterval(async () => {
            try {
                const resp = await fetch(`/ArtistCommission?handler=Messages&commissionId=${selectedCommId}&lastId=${lastMsgId}`);
                const messages = await resp.json();
                if (messages.length > 0) {
                    const chatEl = document.getElementById('chatArea');
                    messages.forEach(msg => {
                        const displayName = msg.isArtist ? 'You' : '@@' + msg.senderUsername;
                        const bubbleClass = msg.isArtist ? 'self' : 'other';
                        const div = document.createElement('div');
                        div.className = 'chat ' + bubbleClass;
                        div.dataset.msgId = msg.id;
                        div.innerHTML = `<span class="user">${displayName}</span><div class="bubble">${msg.message}</div><span class="time">${msg.time}</span>`;
                        chatEl.appendChild(div);
                        lastMsgId = msg.id;
                    });
                    chatEl.scrollTop = chatEl.scrollHeight;
                }
            } catch(e) {}
        }, 3000);
    }
</script>

<!-- Status Change Confirmation Modal -->
<div id="statusModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:99999; justify-content:center; align-items:center;">
    <div style="background:white; border-radius:12px; padding:20px 25px; min-width:300px; max-width:400px; box-shadow:0 10px 40px rgba(0,0,0,0.3); font-family:'Inter',sans-serif;">
        <p id="statusModalText" style="font-size:1rem; font-weight:600; color:#1b1b1b; margin-bottom:18px;"></p>
        <div style="display:flex; justify-content:flex-end; gap:10px;">
            <button onclick="document.getElementById('statusModal').style.display='none'" style="padding:6px 20px; border:2px solid #1b1b1b; background:white; border-radius:20px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.85rem;">Cancel</button>
            <button onclick="document.getElementById('statusForm').submit()" style="padding:6px 20px; border:none; background:#3E4A8E; color:white; border-radius:20px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.85rem;">OK</button>
        </div>
    </div>
</div>

<script>
    function showStatusModal(newStatus) {
        document.getElementById('statusModalText').textContent = 'Change status to ' + newStatus + '?';
        document.getElementById('statusModal').style.display = 'flex';
    }
</script>

</body>
</html>
