@page
@model ArtOnline.Pages.LoginModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="~/css/login.css">
</head>

<body>
    <img src="~/assets/LOGO 2 ALT.png" class="bgpic">

    <div class="mid">
        <div class="tab">
            <div class="top">
                <img src="~/assets/MAIN LOGO.png" alt="MAIN-LOGO">
                <h2>Sign In</h2>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <p class="error-message">@Model.ErrorMessage</p>
            }

            <form method="post">
                <div class="input">
                    <p>Username</p>
                    <input type="text" class="box" name="Username" value="@Model.Username">
                </div>

                <div class="input">
                    <p>Password</p>
                    <div class="passwrap">
                        <input type="password" class="box" name="Password">
                        <button type="button" class="see">
                            <span class="material-symbols-rounded">visibility_off</span>
                        </button>
                    </div>
                </div>
                
                <button type="submit" class="logbtn">Log In</button>
            </form>

            <div class="create">
                <p>Dont have an account yet?</p>
                <a href="/Signup">Create Account</a>
            </div>
        </div>
    </div>
    
    <div class="footer">
        <p>&copy; Art Online, 2026. All rights reserved.</p>
        <div class="cont">
            <p>Connect w/ Developers:</p>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
            </svg>
            <a href="">developers@gmail.com</a>
        </div>
    </div>
    
<script>
    document.querySelectorAll('.see').forEach(btn => {
        btn.addEventListener('click', () => {
            const input = btn.parentElement.querySelector('input');
            const icon = btn.querySelector('span');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        });
    });
</script>
</body>
</html>
