@page
@model ArtOnline.Pages.SettingsModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings:Account</title>
    <link rel="stylesheet" href="~/css/setacc.css">
</head>

<body>
    <img src="~/assets/LOGO 2 ALT.png" class="bgpic">

    <div class="header">
        <div class="left">
            <img src="~/assets/LOGO 2.png" alt="LOGO-2" border="0">
            <h1>ArtOnline</h1>
        </div>
        <div class="right">
            <a class="home" href="/Home">Home</a>
            <a class="gallery">Gallery</a>
            <a class="comm" href="/Commission">Commission</a>
            <a class="artist">Artist</a>
            <a class="set" href="/Settings">Settings</a>
        </div>
    </div>

    <div class="mid">
        <div class="ml">
            <div class="tabui">
                <div class="tabid">
                    <h1>Profile</h1>
                    <span class="material-symbols-rounded">edit_square</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <p class="success-message">@Model.SuccessMessage</p>
                }
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <p class="error-message">@Model.ErrorMessage</p>
                }

                <form method="post" asp-page-handler="Profile">
                    <div class="top">
                        <div class="inputs">
                            <div class="input">
                                <p>Email Address</p>
                                <input type="text" class="box" name="Email" value="@Model.Email">
                            </div>
                            <div class="input">
                                <p>Username</p>
                                <input type="text" class="box" name="Username" value="@Model.Username">
                            </div>
                            <div class="input">
                                <p>Age</p>
                                <input type="text" class="box" name="Age" value="@Model.Age">
                            </div>
                            <div class="input">
                                <p>Gender</p>
                                <input type="text" class="box" name="Gender" value="@Model.Gender">
                            </div>
                        </div>
                        <div class="btnwrap">
                            <button type="submit" class="save">Save Changes</button>
                        </div>
                    </div>
                </form>

                <form method="post" asp-page-handler="Password">
                    <div class="bot">
                        <p class="change">Change Password (Leave blank to remain unchanged)</p>
                        <div class="inputs">
                            <div class="input">
                                <p>Enter Current Password</p>
                                <input type="password" class="box" name="CurrentPassword">
                            </div>
                            <div class="input">
                                <p>New Password</p>
                                <input type="password" class="box" name="NewPassword">
                            </div>
                            <div class="input">
                                <p>Re-enter new Password</p>
                                <input type="password" class="box" name="ConfirmNewPassword">
                            </div>
                        </div>
                        <div class="btnwrap">
                            <button type="submit" class="save">Save Changes</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <div class="mr">
            <div class="setui">
                <div class="iconwrap">
                    <span class="material-symbols-rounded">settings</span>
                </div>
                <div class="divwrap">
                    <div class="set1">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Account</p>
                    </div>
                    <div class="set2">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>FAQs</p>
                    </div>
                    <div class="set3">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Reviews</p>
                    </div>
                    <div class="set4">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Terms</p>
                    </div>
                    <div class="set5">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Privacy Policy</p>
                    </div>
                </div>
                <img src="~/assets/MAIN LOGO.png" alt="MAIN-LOGO" border="0">
                <div class="iconwrap">
                    <a href="/Logout"><span class="exit material-symbols-rounded">exit_to_app</span></a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="footer">
        <p>&copy; Art Online, 2026. All rights reserved.</p>
        <div class="cont">
            <p>Connect w/ Developers:</p>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
            </svg>
            <a href="">developers@gmail.com</a>
        </div>
    </div>
    
<script>
    document.querySelectorAll('.see').forEach(btn => {
        btn.addEventListener('click', () => {
            const input = btn.parentElement.querySelector('input');
            const icon = btn.querySelector('span');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        });
    });
</script>
</body>
</html>
