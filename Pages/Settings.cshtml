@page
@model ArtOnline.Pages.SettingsModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings:Account</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <link rel="stylesheet" href="~/css/setacc.css">
</head>

<body>
    <img src="~/assets/LOGO 2 ALT.png" class="bgpic">

    <div class="header">
        <div class="left">
            <img src="~/assets/LOGO 2.png" alt="LOGO-2" border="0">
            <h1>ArtOnline</h1>
        </div>
        <div class="right">
            <a class="home" href="/Home">Home</a>
            <a class="gallery" href="/Gallery">Gallery</a>
            <a class="comm" href="/Commission">Commission</a>
            <a class="artist" href="/Artist">Artist</a>
            <a class="set" href="/Settings">Settings</a>
        </div>
    </div>

    <div class="mid">
        <div class="ml">
            <div class="tabui" style="overflow:hidden; padding-bottom:0;">
                <div class="tabid">
                    <h1>Profile</h1>
                    <span class="material-symbols-rounded">edit_square</span>
                </div>

                <div style="overflow-y:auto; flex:1; height:0; padding-top:20px; padding-bottom:25px;">
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <p style="padding:10px 24px; margin-bottom:5px; font-family:'Inter',sans-serif; font-size:0.9rem; font-weight:600; color:#2e7d32;">@Model.SuccessMessage</p>
                }
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <p style="padding:10px 24px; margin-bottom:5px; font-family:'Inter',sans-serif; font-size:0.9rem; font-weight:600; color:#9e3e3e;">@Model.ErrorMessage</p>
                }

                <form method="post" asp-page-handler="Profile">
                    <div class="top">
                        <div class="inputs">
                            <div class="input">
                                <p>Email Address</p>
                                <input type="text" class="box" name="Email" value="@Model.Email">
                            </div>
                            <div class="input">
                                <p>Username</p>
                                <input type="text" class="box" name="Username" value="@Model.Username">
                            </div>
                            <div class="input">
                                <p>First Name</p>
                                <input type="text" class="box" name="FirstName" value="@Model.FirstName">
                            </div>
                            <div class="input">
                                <p>Last Name</p>
                                <input type="text" class="box" name="LastName" value="@Model.LastName">
                            </div>
                            <div class="input">
                                <p>Age</p>
                                <input type="text" class="box" name="Age" value="@Model.Age">
                            </div>
                            <div class="input">
                                <p>Gender</p>
                                <input type="text" class="box" name="Gender" value="@Model.Gender">
                            </div>
                        </div>
                        <div class="btnwrap">
                            <button type="submit" class="save">Save Changes</button>
                        </div>
                    </div>
                </form>

                <form method="post" asp-page-handler="Password">
                    <div class="bot">
                        <p class="change">Change Password (Leave blank to remain unchanged)</p>
                        <div class="inputs">
                            <div class="input">
                                <p>Enter Current Password</p>
                                <input type="password" class="box" name="CurrentPassword">
                            </div>
                            <div class="input">
                                <p>New Password</p>
                                <input type="password" class="box" name="NewPassword">
                            </div>
                            <div class="input">
                                <p>Re-enter new Password</p>
                                <input type="password" class="box" name="ConfirmNewPassword">
                            </div>
                        </div>
                        <div class="btnwrap">
                            <button type="submit" class="save">Save Changes</button>
                        </div>
                    </div>
                </form>
                </div>
            </div>
        </div>
        <div class="mr">
            <div class="setui">
                <div class="iconwrap">
                    <span class="material-symbols-rounded">settings</span>
                </div>
                <div class="divwrap">
                    <a href="/Settings"><div class="set1">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Account</p>
                    </div></a>
                    <a href="/Faqs"><div class="set2">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>FAQs</p>
                    </div></a>
                    <a href="/Reviews"><div class="set3">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Reviews</p>
                    </div></a>
                    <a href="/Terms"><div class="set4">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Terms</p>
                    </div></a>
                    <a href="/Privacy"><div class="set5">
                        <span class="material-symbols-rounded">arrow_back_ios</span>
                        <p>Privacy Policy</p>
                    </div></a>
                </div>
                <img src="~/assets/MAIN LOGO.png" alt="MAIN-LOGO" border="0">
                <div class="iconwrap">
                    <a href="#" onclick="document.getElementById('logoutModal').style.display='flex'; return false;"><span class="exit material-symbols-rounded">exit_to_app</span></a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="footer">
        <p>&copy; Art Online, 2026. All rights reserved.</p>
        <div class="cont">
            <p>Connect w/ Developers:</p>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
            </svg>
            <a href="">developers@gmail.com</a>
        </div>
    </div>
    
<script>
    document.querySelectorAll('.see').forEach(btn => {
        btn.addEventListener('click', () => {
            const input = btn.parentElement.querySelector('input');
            const icon = btn.querySelector('span');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        });
    });
</script>
<!-- Logout Confirmation Modal -->
<div id="logoutModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:99999; justify-content:center; align-items:center;">
    <div style="background:white; border-radius:12px; padding:20px 25px; min-width:300px; max-width:400px; box-shadow:0 10px 40px rgba(0,0,0,0.3); font-family:'Inter',sans-serif;">
        <p style="font-size:1rem; font-weight:600; color:#1b1b1b; margin-bottom:18px;">Are you sure you want to log out?</p>
        <div style="display:flex; justify-content:flex-end; gap:10px;">
            <button onclick="document.getElementById('logoutModal').style.display='none'" style="padding:6px 20px; border:2px solid #1b1b1b; background:white; border-radius:20px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.85rem;">Cancel</button>
            <button onclick="window.location.href='/Logout'" style="padding:6px 20px; border:none; background:#9e3e3e; color:white; border-radius:20px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.85rem;">Log Out</button>
        </div>
    </div>
</div>

</body>
</html>
