@page
@model ArtOnline.Pages.HomeModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="[REDACTED_CONN_STRING]://24,500,1,0">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homepage</title>
    <link rel="stylesheet" href="~/css/home.css">
</head>

<body>
    <img src="~/assets/LOGO 2 ALT.png" class="bgpic">

    <div class="header">
        <div class="left">
            <img src="~/assets/LOGO 2.png" alt="LOGO-2" border="0">
            <h1>ArtOnline</h1>
        </div>
        <div class="right">
            <a class="home" href="/Home">Home</a>
            <a class="gallery">Gallery</a>
            <a class="comm" href="/Commission">Commission</a>
            <a class="artist">Artist</a>
            <a class="set" href="/Settings">Settings</a>
        </div>
    </div>

    <div class="mid">
        <div class="top">
            <div class="tl">
                <h1>Bring Your Ideas To Life<br>Through Art</h1>
                <p>Custom digital commissions made just for you.<br>Portraits, fan art, original characters, and more.</p>
                <div class="btns">
                    <button class="req">Request Commission</button>
                    <button class="view">View Gallery</button>
                </div>
            </div>
            <div class="tm"></div>
            <div class="tr">
                <h1>Choose Your Art Style</h1>
                <div class="cards">
                    <div class="cds">
                        <img src="~/assets/placeholder.jpg" alt="Image" border="0">
                        <p>Line Art</p>
                    </div>
                    <div class="cds">
                        <img src="~/assets/placeholder.jpg" alt="Image" border="0">
                        <p>Fully Rendered</p>
                    </div>
                    <div class="cds">
                        <img src="~/assets/placeholder.jpg" alt="Image" border="0">
                        <p>Custom</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bot">
            <div class="bl">
                <img src="~/assets/placeholder.jpg" alt="Image" border="0">
                <div class="about">
                    <h1>About the Artist</h1>
                    <div class="texts">
                        <h1>Hello! I'm Amoreivc</h1>
                        <p>Freelance digital artist specializing in custom illustrations and character art.</p>
                        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
                        <a href="">Learn more About the Artist ></a>
                    </div>
                </div>
            </div>
            <div class="bm"></div>
            <div class="br">
                <h1>What You Can Expect</h1>
                <div class="stairs">
                    <p class="s1">Rush Commissions</p>
                    <p class="s2">Flexible Pricing</p>
                    <p class="s3">Guest Commissions</p>
                    <p class="s4">Quality Output</p>
                </div>
            </div>
        </div>
    </div>
    <div class="footer">
        <p>&copy; Art Online, 2026. All rights reserved.</p>
        <div class="cont">
            <p>Connect w/ Developers:</p>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
            </svg>
            <a href="">developers@gmail.com</a>
        </div>
    </div>
    
</body>

</html>
