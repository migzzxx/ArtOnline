@page
@model ArtOnline.Pages.GalleryModel

<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,500,1,0">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=favorite">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gallery</title>
    <link rel="stylesheet" href="~/css/gallery_userui.css">
</head>

<body>
    <div class="header">
        <div class="left">
            <img src="~/assets/LOGO 2.png" alt="LOGO-2" border="0">
            <h1>ArtOnline</h1>
        </div>
        <div class="right">
            <a class="home" href="/Home">Home</a>
            <a class="gallery" href="/Gallery">Gallery</a>
            <a class="comm" href="/Commission">Commission</a>
            <a class="artist" href="/Artist">Artist</a>
            <a class="set" href="/Settings">Settings</a>
        </div>
    </div>

    <div class="search">
        <div class="bar">
            <input type="text" id="searchInput" placeholder="Search..." value="@Model.SearchQuery">
            <span class="material-symbols-rounded" onclick="doSearch()" style="cursor:pointer;">search</span>
        </div>
        <span class="material-symbols-rounded filter" id="filterBtn" style="cursor:pointer; @(Model.SelectedTag != null ? "background:#3E4A8E; color:white; border-color:#3E4A8E;" : "")">filter_list</span>
        <span class="material-symbols-outlined filter" id="heartFilterBtn" style="cursor:pointer; font-size:1.25rem; @(Model.ShowHearted ? "background:#3E4A8E; color:white; border-color:#3E4A8E;" : "")">favorite</span>
    </div>

    <!-- Tag Filter Modal -->
    <div id="filterModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
        <div style="background:white; border-radius:12px; padding:25px 30px; width:450px; box-shadow:0 10px 40px rgba(0,0,0,0.3); font-family:'Inter',sans-serif;">
            <p style="font-size:1rem; font-weight:600; color:#1b1b1b; margin-bottom:15px;">Filter by Tag</p>
            <div style="display:flex; flex-wrap:wrap; gap:8px; max-height:180px; overflow-y:auto; padding:5px 0;" id="filterTags">
                @foreach (var tag in Model.AllTags)
                {
                    <span class="tag-chip @(Model.SelectedTag == tag.Name ? "active" : "")" data-tag="@tag.Name" onclick="document.querySelectorAll('#filterTags .tag-chip').forEach(t=>t.classList.remove('active')); this.classList.add('active');" style="padding:6px 14px; border:2px solid #3E4A8E; border-radius:20px; font-size:0.85rem; font-weight:600; cursor:pointer;">@tag.Name</span>
                }
            </div>
            <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px;">
                <button class="btn-cancel" onclick="clearFilter()">Clear</button>
                <button class="btn-save" onclick="applyFilter()">Filter</button>
            </div>
        </div>
    </div>

    <div class="wrap">
        <main class="gallery-frame">
            @foreach (var img in Model.Images)
            {
                var isHearted = Model.HeartedImageIds.Contains(img.Id);
                <div class="card" data-hearts="@img.HeartCount" style="background-image:url('@img.ImagePath');" onclick="viewImage(@img.Id, '@img.Title.Replace("'", "\\'")', '@img.Description.Replace("'", "\\'")', '@img.Tags', @img.HeartCount, '@img.DateAdded.ToString("MMM dd, yyyy")', '@img.ImagePath')">
                    <div class="card-info">
                        <strong>@img.Title</strong>
                        <span>@img.Description</span>
                    </div>
                    <button class="like" data-id="@img.Id" onclick="event.stopPropagation(); toggleHeart(this, @img.Id);">
                        <span class="like-count">@img.HeartCount</span>
                        <span class="material-symbols-outlined" style="font-size:16px; @(isHearted ? "color:#ff69b4;" : "color:white;")">favorite</span>
                    </button>
                </div>
            }
        </main>
    </div>

    <div class="footer">
        <p>&copy; Art Online, 2026. All rights reserved.</p>
        <div class="cont">
            <p>Connect w/ Developers:</p>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
                <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
            </svg>
            <a href="">developers&#64;gmail.com</a>
        </div>
    </div>

    <!-- View Image Modal (no edit/delete) -->
    <div class="gallery-modal" id="viewModal">
        <div class="gallery-modal-content">
            <div class="modal-left">
                <img id="viewImg" src="" style="max-width:100%; max-height:100%; object-fit:contain;">
            </div>
            <div class="modal-right" id="viewRight">
                <div id="viewDetails">
                    <div class="detail-row"><label>Title</label><p id="viewTitle"></p></div>
                    <div class="detail-row"><label>Description</label><p id="viewDesc"></p></div>
                    <div class="detail-row"><label>Tags</label><p id="viewTags"></p></div>
                    <div class="detail-row"><label>Hearts</label><p id="viewHearts"></p></div>
                    <div class="detail-row"><label>Date Added</label><p id="viewDate"></p></div>
                </div>
                <div class="modal-buttons">
                    <button type="button" class="btn-cancel" onclick="closeViewModal()">Close</button>
                </div>
            </div>
        </div>
    </div>

<script>
    // Search
    function doSearch() {
        const q = document.getElementById('searchInput').value;
        window.location.href = '/Gallery?search=' + encodeURIComponent(q);
    }
    document.getElementById('searchInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') doSearch(); });

    // Filter by tag
    document.getElementById('filterBtn').addEventListener('click', () => {
        document.getElementById('filterModal').style.display = 'flex';
    });

    function clearFilter() {
        document.querySelectorAll('#filterTags .tag-chip').forEach(t => t.classList.remove('active'));
    }

    function applyFilter() {
        const selected = document.querySelector('#filterTags .tag-chip.active');
        if (selected) {
            window.location.href = '/Gallery?tag=' + encodeURIComponent(selected.dataset.tag);
        } else {
            window.location.href = '/Gallery';
        }
    }

    // Heart filter
    document.getElementById('heartFilterBtn').addEventListener('click', () => {
        const isActive = '@Model.ShowHearted' === 'True';
        if (isActive) {
            window.location.href = '/Gallery';
        } else {
            window.location.href = '/Gallery?hearted=true';
        }
    });

    // Toggle heart on a card
    async function toggleHeart(btn, imageId) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const formData = new FormData();
        formData.append('imageId', imageId);

        const response = await fetch('/Gallery?handler=Heart', {
            method: 'POST',
            headers: { 'RequestVerificationToken': token },
            body: formData
        });

        if (response.ok) {
            const data = await response.json();
            if (data.success) {
                const countEl = btn.querySelector('.like-count');
                const heartIcon = btn.querySelector('.material-symbols-outlined');
                countEl.textContent = data.newCount;
                // Update the card's onclick attribute heart count for view modal
                btn.closest('.card').dataset.hearts = data.newCount;
                if (data.hearted) {
                    heartIcon.style.color = "#ff69b4";
                } else {
                    heartIcon.style.color = "white";
                }
            }
        }
    }

    // View Image Modal
    function viewImage(id, title, desc, tags, hearts, date, imgPath) {
        // Get live heart count from the card's data attribute
        const card = document.querySelector('.card[data-hearts]');
        const cards = document.querySelectorAll('.card');
        let liveHearts = hearts;
        cards.forEach(c => {
            if (c.dataset.hearts !== undefined && c.querySelector('.like-count')) {
                // Find the card that was clicked by matching image path
                if (c.style.backgroundImage.includes(imgPath.replace(/'/g, ''))) {
                    liveHearts = c.dataset.hearts;
                }
            }
        });
        document.getElementById('viewImg').src = imgPath;
        document.getElementById('viewTitle').textContent = title;
        document.getElementById('viewDesc').textContent = desc || '(none)';
        document.getElementById('viewTags').textContent = tags || '(none)';
        document.getElementById('viewHearts').textContent = liveHearts;
        document.getElementById('viewDate').textContent = date;
        document.getElementById('viewModal').classList.add('show');
    }

    function closeViewModal() {
        document.getElementById('viewModal').classList.remove('show');
    }
</script>

<!-- Anti-forgery token for fetch requests -->
<form id="tokenForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>

</body>
</html>
